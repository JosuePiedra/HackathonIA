# Renombrá este archivo a ".env.example" (o copialo a ".env.local" con tus valores).
# Los permisos del entorno bloquean escribir archivos .env* directamente.

# ── Supabase (fuente de datos, siempre conectada) ──
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ── Motor LLM del agente ──
# Elegí el proveedor: "anthropic" o "gemini".
# También se puede fijar en código en lib/llm.ts (constante LLM_PROVIDER).
LLM_PROVIDER=gemini

# API keys (solo se usa la del proveedor seleccionado). Nunca se exponen al cliente.
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...

# Modelos (opcionales — valores por defecto si se omiten)
ANTHROPIC_MODEL=claude-sonnet-4-20250514
GEMINI_MODEL=gemini-2.0-flash
