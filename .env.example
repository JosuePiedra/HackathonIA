# ============================================================
# HackathonIA — variables de entorno unificadas
# Copiá este archivo a .env y completá los valores reales.
# NUNCA subas .env al repositorio.
# ============================================================

# ── Supabase: API HTTP ───────────────────────────────────────
# Misma URL para backend (Python) y frontend (Next.js).
SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co

# Clave anónima (segura para el cliente / frontend)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...anon...

# Clave de servicio (solo backend — NUNCA al frontend)
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role...

# ── Supabase: conexión PostgreSQL directa (para migraciones) ─
# Obtenerla en: Supabase → Settings → Database → Connection string
# Formato: postgresql://postgres.[ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres
SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@db.[ref].supabase.co:5432/postgres

# ── LLM — proveedor del agente IA ───────────────────────────
# "gemini" o "anthropic"
LLM_PROVIDER=gemini

# Google Gemini
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.5-flash

# Anthropic (solo si LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Pipeline Python ──────────────────────────────────────────
UPLOAD_DIR=data/raw
STAGING_DIR=data/staging
PROCESSED_DIR=data/processed
ENABLE_LLM_MAPPING=true
DEFAULT_MAPPING_CONFIDENCE_THRESHOLD=0.75
