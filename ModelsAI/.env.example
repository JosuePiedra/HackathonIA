# Supabase — usar solo desde backend, nunca exponer en frontend
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Anthropic (legacy, si se usa Claude en vez de Gemini)
ANTHROPIC_API_KEY=

# Directorios de trabajo
UPLOAD_DIR=data/raw
STAGING_DIR=data/staging
PROCESSED_DIR=data/processed

# Pipeline
ENABLE_LLM_MAPPING=true
DEFAULT_MAPPING_CONFIDENCE_THRESHOLD=0.75